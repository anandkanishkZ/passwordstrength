# Node `pg` + Neon: if you see SSL / libpq hints, try either:
#   ?sslmode=verify-full   (stricter, current Neon default behaviour)
#   ?sslmode=require&uselibpqcompat=true   (libpq-compatible; see PostgreSQL libpq-ssl docs)
DATABASE_URL=postgresql://user:pass@host:5432/dbname?sslmode=require&uselibpqcompat=true
JWT_SECRET=replace_with_strong_random_secret
JWT_EXPIRES_IN=15m
REFRESH_SECRET=replace_with_strong_refresh_secret
REFRESH_EXPIRES_IN=7d

# Google reCAPTCHA v3 secret key (server-side; pair with VITE_RECAPTCHA_SITE_KEY on the frontend)
RECAPTCHA_SECRET=your_secret_key_here
# Minimum score 0.0–1.0. Use ~0.3 for local dev; 0.5–0.7 typical in production.
# RECAPTCHA_MIN_SCORE=0.3

# Local dev only: skip reCAPTCHA verify (ignored when NODE_ENV=production). Fixes Google "browser-error" on some setups.
# RECAPTCHA_SKIP_VERIFY=1

# Behind a reverse proxy (Railway, Render, etc.) so clientIp / rate limits see real client IP.
# TRUST_PROXY=1

# Comma-separated allowed browser origins (must match exactly, including port).
FRONTEND_URL=http://localhost:5173,http://localhost:8080,http://127.0.0.1:8080

# Lockout after N wrong passwords (default 3); lockout duration in minutes (default 15).
# MAX_FAILED_LOGIN_ATTEMPTS=3
# LOCKOUT_DURATION_MINUTES=15
# Recommend password change when older than N days (default 30).
# PASSWORD_MAX_AGE_DAYS=30
